{
  "name": "@openclaw/operator",
  "version": "0.0.0-private",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "bin": {
    "operator": "./dist/cli/entry.mjs"
  },
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts src/cli/entry.ts --no-config --platform node --format esm --dts --out-dir dist --clean",
    "typecheck": "tsc --noEmit",
    "typecheck:src": "tsc --noEmit --project tsconfig.src.json",
    "verify": "npm run typecheck:src && npm run build && npm test",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
